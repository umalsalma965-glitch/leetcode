class Solution:
    def convert(self, s, numRows):

        if numRows == 1 or numRows >= len(s):
            return s

        rows = [""] * numRows

        currentRow = 0
        goingDown = False

        for ch in s:

            rows[currentRow] += ch

            if currentRow == 0 or currentRow == numRows - 1:
                goingDown = not goingDown

            if goingDown:
                currentRow += 1
            else:
                currentRow -= 1

        return "".join(rows)
